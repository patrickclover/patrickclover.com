{
	"name": "patrickclover.com",
	"version": "1.0.0",
	"main": "src/index.tsx",
	"repository": "https://github.com/patrickclover/patrickclover.com.git",
	"author": "patrickclover <im@patrickclover.com>",
	"license": "MIT",
	"scripts": {
		"start": "react-scripts start",
		"build": "react-scripts build",
		"test": "react-scripts test",
		"eject": "react-scripts eject",
		"cstart": "PUBLIC_URL=/ WDS_SOCKET_PATH=$PUBLIC_URL/sockjs-node BROWSER=none yarn start"
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"plugin:react-hooks/recommended",
			"prettier"
		],
		"rules": {
			"additional-rule": "warn"
		},
		"overrides": [
			{
				"files": [
					"**/*.ts?(x)"
				],
				"rules": {
					"additional-typescript-only-rule": "warn"
				}
			}
		]
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@types/react": "^18.2.55",
		"@types/react-dom": "^18.2.19",
		"eslint": "^8.56.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-jsx-a11y": "^6.8.0",
		"eslint-plugin-prettier": "^5.1.3",
		"eslint-plugin-react": "^7.33.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"husky": "^9.0.10",
		"lint-staged": "^15.2.1",
		"prettier": "^3.2.5",
		"typescript": "^5.3.3"
	},
	"dependencies": {
		"classnames": "^2.5.1",
		"motion": "^11.0.3",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-scripts": "5.0.1"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
			"prettier --write"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	}
}